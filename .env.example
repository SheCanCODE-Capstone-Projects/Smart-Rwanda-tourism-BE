# PostgreSQL
POSTGRES_DB=smart_rwanda_tourism
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

# Spring Boot datasource
# Use localhost for local dev, db (Docker service name) inside Docker Compose
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/smart_rwanda_tourism
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=change_me

# Application
SERVER_PORT=8080

# JWT
# JWT_SECRET must be a Base64-encoded string of at least 32 bytes
JWT_SECRET=replace_with_base64_encoded_secret_at_least_32_bytes
JWT_EXPIRATION=86400000

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Mail (Gmail SMTP — leave blank to disable email features)
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=your_app_password
